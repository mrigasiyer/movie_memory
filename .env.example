# ── Database (hosted Postgres — Supabase) ─────────────────────────────────────
# Supabase dashboard → Project Settings → Database → Connection string.
# Pooled connection used by the running app (Transaction pooler, port 6543).
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"
# Direct connection used by `prisma migrate` (Session/direct, port 5432).
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── Auth.js (NextAuth v5) ─────────────────────────────────────────────────────
# A random secret used to sign the session cookie. Generate with:
#   openssl rand -base64 33
AUTH_SECRET="replace-me"
# Google OAuth client credentials (Google Cloud Console → APIs & Services → Credentials).
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"
# Base URL of the app (used by NextAuth for callback URLs).
AUTH_URL="http://localhost:3000"

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
